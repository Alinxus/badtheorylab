SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=
FROM_EMAIL=
SMTP_SECURE=true
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# Hackathon registrations → Supabase table `hackathon_registrations`
# (GET /api/setup-db prints the SQL to create it). The confirmation email
# reuses the SMTP_* + FROM_EMAIL vars above.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_DISCORD_URL=
# Optional comma-separated domains to reject in addition to the built-in disposable list.
BLOCKED_HACKATHON_EMAIL_DOMAINS=
